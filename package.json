{
  "name": "daily-intelligence-aggregator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:audit": "playwright test tests/smoke tests/routes tests/navigation tests/responsive tests/audit",
    "test:e2e:audit:chromium": "playwright test tests/smoke tests/routes tests/navigation tests/responsive tests/audit --project=chromium",
    "audit:ui:report": "node scripts/playwright-ui-audit-report.mjs",
    "governance:coverage": "python3 scripts/validate-documentation-coverage.py",
    "governance:audit": "python3 scripts/pr-governance-audit.py",
    "governance:hotspots": "python3 scripts/check-governance-hotspots.py",
    "release:local": "node scripts/release/validate-local.mjs",
    "release:preview": "node scripts/release/verify-deployment.mjs --stage preview",
    "release:production": "node scripts/release/verify-deployment.mjs --stage production",
    "release:docs": "node scripts/release/generate-release-docs.mjs",
    "release:pr-summary": "node scripts/release/generate-pr-summary.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
