NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_EMAILS=newsweb2026@gmail.com,brandonma25@gmail.com
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
THE_NEWS_API_KEY=your_news_api_key

# PRD-61 newsletter ingestion. Keep real OAuth values in deployment secrets/env only.
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_oauth_refresh_token
GMAIL_NEWSLETTER_LABEL=bootup-news-benchmark
NEWSLETTER_INGESTION_ENABLED=false
NEWSLETTER_INGESTION_DRY_RUN=true
NEWSLETTER_INGESTION_MAX_EMAILS_PER_RUN=10
NEWSLETTER_INGESTION_SINCE_HOURS=36
ALLOW_PRODUCTION_NEWSLETTER_INGESTION=false
NEWSLETTER_INGESTION_TEST_RUN_ID=

# Sentry RSS monitoring. Keep real values in deployment secrets/env only.
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_public_browser_sentry_dsn
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug
SENTRY_AUTH_TOKEN=
RSS_CRON_MONITOR_SLUG=rss-feed-refresh
RSS_STALE_THRESHOLD_MS=108000000
PUBLIC_SITE_URL=https://bootupnews.com

# Editorial automation pipeline (Spec: Boot Up Editorial Automation Pipeline)
# NOTION_TOKEN: Notion integration token (same as Notion MCP workspace token)
NOTION_TOKEN=your_notion_integration_token
# NOTION_EDITORIAL_QUEUE_DB_ID: Set automatically after Task 1 runs
NOTION_EDITORIAL_QUEUE_DB_ID=56caed793822497e8e58e8dc2291d395
# RESEND_API_KEY: Resend transactional email API key (resend.com)
RESEND_API_KEY=your_resend_api_key
# EDITORIAL_PUSH_SECRET: Auth token for /api/editorial/push-approved?token=...
EDITORIAL_PUSH_SECRET=your_editorial_push_secret

# PRD-65 — external scheduling (cron-job.org) for /api/cron/fetch-editorial-inputs.
# CRON_SECRET: shared secret sent by cron-job.org as the `x-cron-secret` header.
# Configure in Vercel project env vars; the same value must be set on each
# cron-job.org job's custom header. Missing or mismatched → endpoint returns 401.
CRON_SECRET=your_cron_secret
# ALLOW_VERCEL_CRON_FALLBACK: rollback escape hatch. When `true`, the endpoint
# also accepts the legacy Vercel Cron `Authorization: Bearer <CRON_SECRET>`
# header. Default behavior is x-cron-secret header only — leave as `false`
# unless re-enabling Vercel Cron during a cron-job.org outage.
ALLOW_VERCEL_CRON_FALLBACK=false

# PRD-65 Phase 4 — operational logging in Notion.
# NOTION_PIPELINE_LOG_DB_ID: Notion database ID for the Pipeline Log (one row
# per ingestion run and per health check). Schema lives at
# docs/notion-pipeline-log-schema.md. If unset, the ingestion and health
# endpoints log a warning and continue — pipeline-log writes are best-effort.
NOTION_PIPELINE_LOG_DB_ID=
# NOTION_SOURCE_HEALTH_LOG_DB_ID: Notion database ID for the Source Health Log
# (per-source-per-day RSS fetch outcomes). Schema lives at
# docs/notion-source-health-schema.md. If unset, the writer logs a warning
# and continues — the ingestion run is unaffected. Phase 4.5's circuit
# breaker also reads this database.
NOTION_SOURCE_HEALTH_LOG_DB_ID=

# PostHog product analytics. Keep real project tokens in deployment env only.
NEXT_PUBLIC_ENABLE_POSTHOG=0
NEXT_PUBLIC_POSTHOG_TOKEN=your_posthog_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=0
NEXT_PUBLIC_POSTHOG_REPLAY_SAMPLE_RATE=1
NEXT_PUBLIC_POSTHOG_PAGEVIEWS=0
NEXT_PUBLIC_POSTHOG_AUTOCAPTURE=0
NEXT_PUBLIC_POSTHOG_HEATMAPS=0
NEXT_PUBLIC_POSTHOG_DEAD_CLICKS=0
